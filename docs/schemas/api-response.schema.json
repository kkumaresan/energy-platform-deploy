{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://energy-platform/schemas/api-response",
  "title": "API Response Envelope",
  "description": "Standard response format for all API gateway endpoints",
  "type": "object",
  "required": ["status", "data"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "data": {
      "description": "Response payload"
    },
    "error": {
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "page": { "type": "integer" },
        "per_page": { "type": "integer" },
        "total": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  }
}
