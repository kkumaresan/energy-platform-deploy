{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Factory Power (kW)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "kwatt"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"energy_data\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"machine_power\" and r._field == \"power_kw\")\n  |> aggregateWindow(every: v.windowPeriod, fn: sum, createEmpty: false)\n  |> yield(name: \"total\")"
        }
      ]
    },
    {
      "title": "Power per Machine (kW)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": false
          },
          "unit": "kwatt"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"energy_data\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"machine_power\" and r._field == \"power_kw\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "title": "Machine Status",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "mappings": [
            { "type": "value", "options": { "running": { "color": "green", "text": "Running" } } },
            { "type": "value", "options": { "idle": { "color": "yellow", "text": "Idle" } } },
            { "type": "value", "options": { "off": { "color": "gray", "text": "Off" } } },
            { "type": "value", "options": { "fault": { "color": "red", "text": "Fault" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"energy_data\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"machine_status\" and r._field == \"state\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)"
        }
      ]
    },
    {
      "title": "Current Power by Machine",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "kwatt"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"energy_data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"machine_power\" and r._field == \"power_kw\")\n  |> last()"
        }
      ]
    },
    {
      "title": "Temperature by Machine (°C)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "celsius",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"energy_data\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"machine_power\" and r._field == \"temperature\")\n  |> last()"
        }
      ]
    },
    {
      "title": "Voltage (V)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "volt",
          "custom": { "lineWidth": 1 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"energy_data\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"machine_power\" and r._field == \"voltage\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "title": "Power Factor",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none",
          "custom": { "lineWidth": 1 },
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"energy_data\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"machine_power\" and r._field == \"power_factor\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "title": "Compressor Pressure (bar)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "pressurebar",
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"energy_data\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"machine_power\" and r._field == \"pressure\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ]
    },
    {
      "title": "Energy Consumption (kWh) — Last 24h",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "kwatth"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "stacking": "none"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"energy_data\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"machine_power\" and r._field == \"power_kw\")\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({r with _value: r._value * 1.0}))\n  |> group(columns: [\"machine_id\"])\n  |> sum()"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["energy", "factory"],
  "templating": {
    "list": [
      {
        "name": "DS_INFLUXDB",
        "type": "datasource",
        "query": "influxdb",
        "current": { "text": "InfluxDB", "value": "InfluxDB" },
        "hide": 2
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Factory Energy Monitor",
  "uid": "factory-energy-monitor"
}
